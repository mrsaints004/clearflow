# Backend
PORT=3002
NODE_ENV=development

# ─── Canton Connection ───────────────────────────────────────────────
# Local development (standalone mode — used when devnet is not configured):
# LEDGER_API_URL=http://localhost:7575

# Seaport Devnet (Build on Canton Hackathon):
SEAPORT_DEVNET=true
LEDGER_API_URL=https://ledger-api.validator.devnet.sandbox.fivenorth.io
SEAPORT_PARTY_ID=your-party-id::your-namespace

# OIDC token refresh credentials (token auto-refreshes every 8 hours):
SEAPORT_OIDC_ISSUER=https://auth.sandbox.fivenorth.io/application/o/token/
SEAPORT_OIDC_CLIENT_ID=validator-devnet-m2m
SEAPORT_OIDC_CLIENT_SECRET=your-client-secret-here

# Multi-participant routing (local Canton topology):
# CANTON_PARTICIPANT_URLS=operator=http://localhost:7571,p1=http://localhost:7572,p2=http://localhost:7573,p3=http://localhost:7574

# ─── Authentication ──────────────────────────────────────────────────
APP_SECRET=clearflow-app-secret-change-in-production
JWT_SECRET=clearflow-dev-secret-change-in-production
REQUIRE_AUTH=false
OPERATOR_PASSWORD=operator-secret

# ─── Frontend ────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:3002/api

# ─── CORS ────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=https://clearflow.onrender.com
