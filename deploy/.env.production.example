# ClearFlow Production Environment Variables
# Copy this to /opt/clearflow/.env.production and fill in real values

NODE_ENV=production
PORT=3002

# Authentication (REQUIRED — generate strong random values)
APP_SECRET=generate-a-64-char-random-string-here
JWT_SECRET=generate-a-different-64-char-random-string-here
OPERATOR_PASSWORD=generate-a-strong-operator-password-here
REQUIRE_AUTH=true

# CORS — set to your actual domain
ALLOWED_ORIGINS=https://your-domain.com

# Canton / Seaport Devnet Connection
SEAPORT_DEVNET=true
LEDGER_API_URL=https://ledger-api.validator.devnet.sandbox.fivenorth.io
SEAPORT_PARTY_ID=your-seaport-party-id
SEAPORT_OIDC_ISSUER=https://auth.sandbox.fivenorth.io/application/o/token/
SEAPORT_OIDC_CLIENT_ID=validator-devnet-m2m
SEAPORT_OIDC_CLIENT_SECRET=your-seaport-oidc-client-secret

# Optional: Local Canton (if running your own Canton node instead of Seaport)
# SEAPORT_DEVNET=false
# LEDGER_API_URL=http://localhost:7575
# CANTON_LEDGER_ID=sandbox
